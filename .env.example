# Alpaca Paper Trading — get keys at https://app.alpaca.markets (switch to paper mode)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Telegram — create bot via @BotFather, get chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Strategy parameters (optional — these are the V3 defaults)
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_PCT=0.05
FVG_BODY_RATIO_MIN=1.5
VOLUME_RATIO_MIN=1.5
ATR_MIN_RATIO=0.3
ATR_MAX_RATIO=1.2
GAP_THRESHOLD=0.008
PREMARKET_VOLATILITY_THRESHOLD=0.015
SIGNAL_CUTOFF_HOUR=10
SIGNAL_CUTOFF_MINUTE=30
REWARD_RISK_RATIO=2.0

# Watchlist — comma-separated symbols (start with SPY only for Phase 1)
DEFAULT_WATCHLIST=SPY

# Database (defaults to local SQLite — upgrade to PostgreSQL URL for production)
DATABASE_URL=sqlite:///one_candle_trade.db
